# LLM Provider API Keys (uses 1Password op:// references, resolved at runtime via `op run`)
# The app auto-detects the provider based on which key is set (checked in order: Anthropic → OpenAI → Gemini)

# Anthropic (Claude) — uncomment and add op:// reference when you have a key
# ANTHROPIC_API_KEY=op://Private/<item-id>/credential

# OpenAI (GPT) — uncomment and add op:// reference when you have a key
# OPENAI_API_KEY=op://Private/<item-id>/credential

# Google Gemini (free tier)
GEMINI_API_KEY=op://Private/s3bdpx5q5clmf2u6nslm4twv2a/api-key

# Optional: override the default model for whichever provider is active
# SUDOKU_LLM_MODEL=gemini-2.0-flash
